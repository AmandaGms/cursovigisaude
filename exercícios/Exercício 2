#1 - Criar script que confira para que pasta o projeto está apontando e, caso a pasta não exista, crie a pasta; e caso, a pasta já exista configure para a pasta de trabalho correta.

Script para verificar/configurar pasta de trabalho no Google Drive (Google Colab)

# Instalar e carregar bibliotecas necessárias
if (!require("googledrive")) install.packages("googledrive")
library(googledrive)

# Autenticação
drive_auth()

# Definir o nome da pasta do projeto
NOME_PASTA <- "Meu_Projeto_R"

# Verificar se a pasta existe
pasta_existente <- tryCatch({
  drive_get(path = NOME_PASTA)
}, error = function(e) {
  return(NULL)
})

# Se não existir, criar a pasta
if (is.null(pasta_existente) || nrow(pasta_existente) == 0) {
  cat("Pasta não encontrada. Criando nova pasta...\n")
  pasta_trabalho <- drive_mkdir(NOME_PASTA)
  cat("Pasta criada com sucesso!\n")
} else {
  cat("Pasta encontrada. Configurando como pasta de trabalho...\n")
  pasta_trabalho <- pasta_existente
}

# Configurar para a pasta de trabalho correta
PASTA_ID <- pasta_trabalho$id
cat(paste("Pasta de trabalho configurada:", NOME_PASTA))
cat(paste("\nID da pasta:", PASTA_ID))


