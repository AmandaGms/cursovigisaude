        Exemplo tirado do script:
          
          install.packages("remotes")
          remotes::install_github("danicat/read.dbc")
          library(read.dbc)
        
        # Lista do banco de dados de sífilis gestacional (2015-2024)
        arquivos <- c(
          "/content/SIFGBR15.dbc",
          "/content/SIFGBR16.dbc",
          "/content/SIFGBR17.dbc",
          "/content/SIFGBR18.dbc",
          "/content/SIFGBR19.dbc",
          "/content/SIFGBR20.dbc",
          "/content/SIFGBR21.dbc",
          "/content/SIFGBR22.dbc",
          "/content/SIFGBR23.dbc",
          "/content/SIFGBR24.dbc"
        )
        lista_dados <- lapply(arquivos, read.dbc)
        
        # Juntar dataframes 
        dados_unicos <- do.call(rbind, lista_dados)

        dados_df <- dados_unicos %>%
        filter(SG_UF==53)

        #descrição raw
        str(dados_df)
        summary(dados_df)

